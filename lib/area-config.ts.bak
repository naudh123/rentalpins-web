// ─── Lookup Helpers ──────────────────────────────────────────────────────────

export const ALL_AREAS: AreaConfig[] = [...CHANDIGARH_AREAS, ...LUDHIANA_AREAS];

export function getAreaConfig(citySlug: string, areaSlug?: string): AreaConfig | undefined {
  if (areaSlug) {
    return ALL_AREAS.find(a => a.slug === areaSlug);
  }
  if (citySlug === "chandigarh") return CHANDIGARH_AREAS[0];
  if (citySlug === "ludhiana")   return LUDHIANA_AREAS[0];
  return undefined;
}
