// ─── app/rentals/[city]/[area]/page.tsx ───────────────────────────────────────
// Dynamic route — handles ALL area sub-pages.
// DEBUG VERSION — with console.logs + Next.js 15 params handling.

import type { Metadata } from "next";
import { notFound } from "next/navigation";
import {
  getAreaBySlug,
  getAllAreas,
  getSiblingAreas,
} from "@/lib/cities-config";
import { fetchAreaListings } from "@/lib/listings";
import { getAreaConfig } from "@/lib/area-config";
import ListingsGrid from "@/components/ListingsGrid";
import AreaClient from "../../../rentals-shared/AreaClient";

export function generateStaticParams() {
  const areas = getAllAreas();
  console.log("📋 generateStaticParams areas:", areas.map(a => `${a.parentSlug}/${a.slug}`));
  return areas.map((area) => ({
    city: area.parentSlug,
    area: area.slug,
  }));
}

export async function generateMetadata({
  params,
}: {
  params: Promise<{ city: string; area: string }> | { city: string; area: string };
}): Promise<Metadata> {
  const resolvedParams = await Promise.resolve(params);
  const result = getAreaBySlug(resolvedParams.city, resolvedParams.area);
  if (!result) return { title: "Not Found" };

  const { city, area } = result;
  const areaNames = area.popularAreas.slice(0, 4).join(", ");

  return {
    title: `Rentals in ${area.name} — ${areaNames} & More | RentalPins`,
    description: `Find rooms, apartments, PG, vehicles, office space and more on rent in ${area.name}. ${area.heroDescription} Contact owners directly on RentalPins. No broker fee.`,
    keywords: [
      `rentals in ${area.name}`,
      ...area.popularAreas.slice(0, 6).map((a) => `${a} ${area.name} rentals`),
      `room for rent ${area.name}`,
      `apartment for rent ${area.name}`,
      `PG in ${area.name}`,
      `RentalPins ${area.name}`,
    ],
    openGraph: {
      title: `Rentals in ${area.name} — ${areaNames} | RentalPins`,
      description: `Browse live rental listings across ${area.name} — property, vehicles, electronics and more on one map. Covering ${areaNames} and more.`,
      url: `https://www.rentalpins.com/rentals/${resolvedParams.city}/${resolvedParams.area}`,
      siteName: "RentalPins",
      images: [{ url: "/og-image.png", width: 1200, height: 630 }],
      locale: "en_IN",
      type: "website",
    },
    twitter: {
      card: "summary_large_image",
      title: `Rentals in ${area.name} | RentalPins`,
      description: `Find rentals on the map across ${area.name}. Free to browse, easy to list.`,
      images: ["/og-image.png"],
    },
    alternates: {
      canonical: `https://www.rentalpins.com/rentals/${resolvedParams.city}/${resolvedParams.area}`,
    },
  };
}

export const revalidate = 7200;

export default async function AreaPage({
  params,
}: {
  params: Promise<{ city: string; area: string }> | { city: string; area: string };
}) {
  const resolvedParams = await Promise.resolve(params);

  console.log("🔍 AreaPage params:", resolvedParams);

  const result = getAreaBySlug(resolvedParams.city, resolvedParams.area);
  console.log("🔍 AreaPage result found:", result ? `${result.city.slug}/${result.area.slug}` : "NOT FOUND");

  if (!result) {
    console.log("❌ AreaPage: area not found in config, returning 404");
    notFound();
  }

  const { city, area } = result;

  let listings: any[] = [];
  try {
    const areaConfig = getAreaConfig(resolvedParams.city, resolvedParams.area);
    console.log("🔍 AreaPage area config:", areaConfig ? "found" : "not found");
    if (areaConfig) {
      listings = await fetchAreaListings(areaConfig, 20);
      console.log("🔍 AreaPage listings fetched:", listings.length);
    }
  } catch (err) {
    console.error("⚠️ AreaPage listings fetch failed:", err);
  }

  const spokeLinks = getSiblingAreas(resolvedParams.city, resolvedParams.area);

  const areaData = {
    name: area.name,
    slug: area.slug,
    parentCity: city.name,
    parentSlug: city.slug,
    country: city.country,
    tagline: area.tagline,
    badge: area.badge,
    primaryFocus: area.primaryFocus,
    heroDescription: area.heroDescription,
    coordinates: area.coordinates,
    popularAreas: area.popularAreas,
    topCategories: area.topCategories,
    popularSearches: area.popularSearches,
    spokeLinks,
    faqs: area.faqs,
    ctaHeading: area.ctaHeading,
    ctaBody: area.ctaBody,
  };

  const jsonLd = {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    name: `RentalPins ${area.name}`,
    description: area.heroDescription,
    url: `https://www.rentalpins.com/rentals/${resolvedParams.city}/${resolvedParams.area}`,
    image: "https://www.rentalpins.com/logo/logo.png",
    telephone: "+91-9915209240",
    email: "support@rentalpins.com",
    geo: {
      "@type": "GeoCoordinates",
      latitude: area.coordinates.lat,
      longitude: area.coordinates.lng,
    },
    areaServed: area.popularAreas.map((a) => ({ "@type": "City", name: a })),
    parentOrganization: {
      "@type": "Organization",
      name: "RentalPins",
      url: "https://www.rentalpins.com",
    },
  };

  const breadcrumbJsonLd = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://www.rentalpins.com" },
      { "@type": "ListItem", position: 2, name: "Rentals", item: "https://www.rentalpins.com/rentals" },
      { "@type": "ListItem", position: 3, name: city.name, item: `https://www.rentalpins.com/rentals/${city.slug}` },
      { "@type": "ListItem", position: 4, name: area.name, item: `https://www.rentalpins.com/rentals/${resolvedParams.city}/${resolvedParams.area}` },
    ],
  };

  const faqJsonLd =
    area.faqs.length > 0
      ? {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          mainEntity: area.faqs.map((f) => ({
            "@type": "Question",
            name: f.q,
            acceptedAnswer: { "@type": "Answer", text: f.a },
          })),
        }
      : null;

  console.log("✅ AreaPage rendering:", `${city.slug}/${area.slug}`);

  return (
    <>
      <script type="application/ld+json" dangerouslySetInnerHTML={{ __html: JSON.stringify(jsonLd) }} />
      <script type="application/ld+json" dangerouslySetInnerHTML={{ __html: JSON.stringify(breadcrumbJsonLd) }} />
      {faqJsonLd && (
        <script type="application/ld+json" dangerouslySetInnerHTML={{ __html: JSON.stringify(faqJsonLd) }} />
      )}
      <ListingsGrid listings={listings} areaName={area.name} />
      <AreaClient area={areaData} />
    </>
  );
}