# Copy to .env.local — never commit real secrets.
# Local dev: leave NEXT_PUBLIC_BASE_PATH unset → http://localhost:3000/

# --- Deploy target ---
# staging | production
# Local dev: production-like (no staging banner). Use staging only for /staging deploys.
NEXT_PUBLIC_DEPLOY_ENV=production
# Hosted staging only: NEXT_PUBLIC_BASE_PATH=/staging and NEXT_PUBLIC_DEPLOY_ENV=staging
# NEXT_PUBLIC_BASE_PATH=/staging

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Firebase client (public) — use your Firebase project values ---
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
# Optional: web push (Firebase Cloud Messaging)
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key

# --- Google Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- GA4 ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Auth ---
# Production cutover: set true
NEXT_PUBLIC_REQUIRE_PHONE_VERIFICATION=false
# Local dev: set true + add fictional test numbers in Firebase Console (Phone provider)
# NEXT_PUBLIC_FIREBASE_PHONE_AUTH_TESTING=true

# --- Firebase Admin (server-only) ---
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Cron (server-only) — Vercel Cron: Authorization: Bearer $CRON_SECRET ---
CRON_SECRET=
